# App origin. Must match where you run the app.
BETTER_AUTH_URL=http://localhost:3000

# Generate a long random value.
BETTER_AUTH_SECRET=

# Postgres connection string.
DATABASE_URL=

# Planning Center OAuth app credentials.
# Callback URL to register in Planning Center:
# http://localhost:3000/api/auth/oauth2/callback/planning-center
PLANNING_CENTER_OAUTH_CLIENT_ID=
PLANNING_CENTER_OAUTH_CLIENT_SECRET=

# Optional override if Planning Center org time_zone cannot be read (fallback only).
# The app normally loads timezone from GET /services/v2 (Services Organization).
# NEXT_PUBLIC_ is used only for the brief client loading state before /api/planning-center/organization returns.
# PLANNING_CENTER_TIME_ZONE=America/Los_Angeles
# NEXT_PUBLIC_PLANNING_CENTER_TIME_ZONE=America/Los_Angeles
