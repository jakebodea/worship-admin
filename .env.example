# App origin. Must match where you run the app.
BETTER_AUTH_URL=http://localhost:3000

# Generate a long random value.
BETTER_AUTH_SECRET=

# Supabase Postgres connection string.
DATABASE_URL=

# Planning Center OAuth app credentials.
# Callback URL to register in Planning Center:
# http://localhost:3000/api/auth/oauth2/callback/planning-center
PLANNING_CENTER_OAUTH_CLIENT_ID=
PLANNING_CENTER_OAUTH_CLIENT_SECRET=

# Optional comma-separated service type IDs to exclude globally.
# Example: 12345,67890
PLANNING_CENTER_EXCLUDED_SERVICE_IDS=
