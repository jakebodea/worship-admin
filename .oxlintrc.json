{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "env": {
    "builtin": true,
    "browser": true
  },
  "settings": {
    "react": {
      "version": "19.2"
    }
  },
  "ignorePatterns": [
    ".next/**",
    "out/**",
    "build/**",
    "next-env.d.ts",
    "node_modules/**"
  ],
  "rules": {
    "jest/no-disabled-tests": "off",
    "vitest/require-mock-type-parameters": "off"
  }
}
